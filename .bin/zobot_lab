#!/bin/bash

# zobot_lab - DevContainer-based container management for robotics development

GREEN='\033[0;32m'
CYAN='\033[0;36m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"
WORKSPACE_ROOT="$(dirname "$SCRIPT_DIR")"

GHCR_BASE="ghcr.io/snknitheesh"

# Default config
ROS_DISTRO="jazzy"
CONDA_ENV=""
BUILD_ONLY=false
PULL_BUILD=false
PRUNE_CONTAINER=false

# Show help
show_help() {
    echo -e "${CYAN}Zobot LAB - DevContainer-Based Robotics Development${NC}"
    echo ""
    echo -e "${GREEN}Usage:${NC}"
    echo "  zobot_lab [OPTIONS]"
    echo ""
    echo -e "${GREEN}Options:${NC}"
    echo "  --jazzy               Use ROS Jazzy (default)"
    echo "  --conda <env_name>    Activate conda environment on start"
    echo "  --pull                Pull base image from GHCR, then build overlay"
    echo "  --build               Build base + overlay images locally"
    echo "  --rebuild             Rebuild all images from scratch (no cache)"
    echo "  --prune               Stop and remove containers (keeps images)"
    echo "  --vscode              Open in VS Code (DevContainer)"
    echo "  --help, -h            Show this help message"
    echo ""
    echo -e "${GREEN}Examples:${NC}"
    echo "  zobot_lab                    # Start container with ROS Jazzy"
    echo "  zobot_lab --pull             # Pull base from GHCR + build overlay"
    echo "  zobot_lab --build            # Build base + overlay locally"
    echo "  zobot_lab --rebuild          # Rebuild everything from scratch"
    echo "  zobot_lab --vscode           # Open in VS Code"
    echo "  zobot_lab --prune            # Remove containers"
    echo ""
    echo -e "${CYAN}DevContainer Commands (Alternative):${NC}"
    echo "  code --folder-uri vscode-remote://dev-container+${WORKSPACE_ROOT}/.devcontainer/jazzy/devcontainer.json"
}

# Check if required tools are installed
check_requirements() {
    if ! command -v docker &> /dev/null; then
        echo -e "${RED}Error: Docker is not installed${NC}"
        exit 1
    fi

    if ! command -v docker compose &> /dev/null; then
        echo -e "${RED}Error: Docker Compose is not installed${NC}"
        exit 1
    fi
}

# Setup environment variables for docker-compose
setup_env() {
    # Ensure conda environments directory exists on host
    mkdir -p /lake/.conda_docker 2>/dev/null || true

    # Enable BuildKit for layer caching
    export DOCKER_BUILDKIT=1
    export COMPOSE_DOCKER_CLI_BUILD=1

    # Ensure DISPLAY is set
    export DISPLAY="${DISPLAY:-:0}"

    # Set ROS_DOMAIN_ID to 1 (fixed for this container)
    export ROS_DOMAIN_ID=1
}

# Pull base image from GHCR and build overlay
pull_and_build() {
    local distro=$1

    echo -e "${YELLOW}Pulling base image from GHCR...${NC}"

    setup_env
    cd "$WORKSPACE_ROOT" || exit 1

    if docker pull "${GHCR_BASE}/zobot-lab-${distro}-base:latest"; then
        echo -e "${GREEN}Base image pulled successfully${NC}"
    else
        echo -e "${RED}Failed to pull base image. Are you logged in to ghcr.io?${NC}"
        echo -e "${YELLOW}  gh auth token | docker login ghcr.io -u snknitheesh --password-stdin${NC}"
        return 1
    fi

    # Build overlay on top of pulled base
    echo -e "${YELLOW}Building overlay image...${NC}"
    if docker compose --profile "$distro" build "ros2-${distro}"; then
        echo -e "${GREEN}${distro} overlay image built successfully${NC}"
    else
        echo -e "${RED}${distro} overlay image build failed${NC}"
        return 1
    fi
}

# Build both images locally
build_images() {
    local distro=$1
    local rebuild=${2:-false}

    echo -e "${YELLOW}Building images for ${distro}...${NC}"

    setup_env

    cd "$WORKSPACE_ROOT" || exit 1

    local build_args=""
    if [ "$rebuild" = true ]; then
        build_args="--no-cache --pull"
    fi

    # Build base image first
    if docker compose --profile build build ${build_args} base-dev; then
        echo -e "${GREEN}Base image built successfully${NC}"
    else
        echo -e "${RED}Base image build failed${NC}"
        return 1
    fi

    # Build overlay image
    if docker compose --profile "$distro" build ${build_args} "ros2-${distro}"; then
        echo -e "${GREEN}${distro} image built successfully${NC}"
    else
        echo -e "${RED}${distro} image build failed${NC}"
        return 1
    fi
}

# Start container
start_container() {
    local distro=$1
    local conda_env=$2

    echo -e "${GREEN}Starting ${distro} container...${NC}"

    setup_env

    cd "$WORKSPACE_ROOT" || exit 1

    # Check if images exist (but don't auto-build)
    if ! docker image inspect "${GHCR_BASE}/zobot-lab-${distro}-base:latest" &> /dev/null; then
        echo -e "${RED}Error: Base image not found!${NC}"
        echo -e "${YELLOW}Pull it: zobot_lab --pull${NC}"
        echo -e "${YELLOW}Or build locally: zobot_lab --build${NC}"
        return 1
    fi

    if ! docker image inspect "zobot-lab-${distro}:latest" &> /dev/null; then
        echo -e "${RED}Error: Overlay image not found!${NC}"
        echo -e "${YELLOW}Build it: zobot_lab --pull  (or zobot_lab --build)${NC}"
        return 1
    fi

    # Start container in background
    if docker compose --profile "$distro" up -d "ros2-${distro}"; then
        echo -e "${GREEN}Container started${NC}"

        # Wait for container to be ready
        sleep 2

        # Enter container
        if [ -n "$conda_env" ]; then
            echo -e "${CYAN}Activating conda environment: ${conda_env}${NC}"
            docker compose --profile "$distro" exec "ros2-${distro}" bash -c \
                "source /opt/conda/etc/profile.d/conda.sh && conda activate $conda_env && exec bash"
        else
            docker compose --profile "$distro" exec "ros2-${distro}" bash
        fi
    else
        echo -e "${RED}Failed to start container${NC}"
        return 1
    fi
}

# Prune containers
prune_containers() {
    local distro=$1

    echo -e "${RED}Pruning ${distro} containers...${NC}"

    cd "$WORKSPACE_ROOT" || exit 1

    # Stop and remove containers using docker compose
    docker compose --profile "$distro" down --remove-orphans

    # Also manually stop and remove any orphaned containers with the expected name
    local container_name="ros2-${distro}-dev"
    if docker ps -a --format '{{.Names}}' | grep -q "^${container_name}$"; then
        echo -e "${YELLOW}Removing orphaned container: ${container_name}${NC}"
        docker stop "$container_name" 2>/dev/null || true
        docker rm "$container_name" 2>/dev/null || true
    fi

    echo -e "${GREEN}Pruning complete (containers removed, images kept)${NC}"
    echo -e "${CYAN}To also remove images:${NC}"
    echo -e "${CYAN}  docker rmi zobot-lab-${distro}:latest${NC}"
    echo -e "${CYAN}  docker rmi ${GHCR_BASE}/zobot-lab-${distro}-base:latest${NC}"
    echo -e "${CYAN}Conda environments are preserved at /lake/.conda_docker${NC}"
}

# Open in VS Code
open_vscode() {
    local distro=$1

    echo -e "${CYAN}Opening in VS Code (${distro})...${NC}"

    cd "$WORKSPACE_ROOT" || exit 1

    # Open with specific devcontainer config
    if command -v code &> /dev/null; then
        # Use devcontainer CLI or VS Code command palette
        code --folder-uri "vscode-remote://dev-container+$(echo -n "${WORKSPACE_ROOT}/.devcontainer/${distro}/devcontainer.json" | xxd -plain | tr -d '\n' | sed 's/\(..\)/%\1/g')"
    else
        echo -e "${YELLOW}VS Code not found. Install VS Code or use regular mode.${NC}"
        echo -e "${CYAN}Install: https://code.visualstudio.com/${NC}"
    fi
}

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --jazzy)
            ROS_DISTRO="jazzy"
            shift
            ;;
        --conda)
            CONDA_ENV="$2"
            shift 2
            ;;
        --pull)
            PULL_BUILD=true
            shift
            ;;
        --build)
            BUILD_ONLY=true
            shift
            ;;
        --rebuild)
            BUILD_ONLY=true
            REBUILD=true
            shift
            ;;
        --prune)
            PRUNE_CONTAINER=true
            shift
            ;;
        --vscode)
            VSCODE=true
            shift
            ;;
        --help|-h)
            show_help
            exit 0
            ;;
        *)
            echo -e "${RED}Unknown option: $1${NC}"
            show_help
            exit 1
            ;;
    esac
done

# Main execution
check_requirements

if [ "$PRUNE_CONTAINER" = true ]; then
    prune_containers "$ROS_DISTRO"
elif [ "$PULL_BUILD" = true ]; then
    pull_and_build "$ROS_DISTRO"
elif [ "$BUILD_ONLY" = true ]; then
    build_images "$ROS_DISTRO" "${REBUILD:-false}"
elif [ "$VSCODE" = true ]; then
    open_vscode "$ROS_DISTRO"
else
    start_container "$ROS_DISTRO" "$CONDA_ENV"
fi
