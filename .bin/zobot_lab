#!/bin/bash

# zobot_lab - DevContainer-based container management for robotics development

GREEN='\033[0;32m'
CYAN='\033[0;36m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"
WORKSPACE_ROOT="$(dirname "$SCRIPT_DIR")"

# Default config
ROS_DISTRO="jazzy"
CONDA_ENV=""
BUILD_ONLY=false
PRUNE_CONTAINER=false

# Show help
show_help() {
    echo -e "${CYAN}🤖 Zobot LAB - DevContainer-Based Robotics Development${NC}"
    echo ""
    echo -e "${GREEN}Usage:${NC}"
    echo "  zobot_lab [OPTIONS]"
    echo ""
    echo -e "${GREEN}Options:${NC}"
    echo "  --jazzy               Use ROS Jazzy (default)"
    echo "  --conda <env_name>    Activate conda environment on start"
    echo "  --build               Build images only, don't run"
    echo "  --rebuild             Rebuild images from scratch"
    echo "  --prune               Stop and remove containers and images"
    echo "  --vscode              Open in VS Code (DevContainer)"
    echo "  --help, -h            Show this help message"
    echo ""
    echo -e "${GREEN}Examples:${NC}"
    echo "  zobot_lab                    # Start container with ROS Jazzy"
    echo "  zobot_lab --build            # Build images"
    echo "  zobot_lab --rebuild          # Rebuild from scratch"
    echo "  zobot_lab --vscode           # Open in VS Code"
    echo "  zobot_lab --prune            # Remove containers and images"
    echo ""
    echo -e "${CYAN}DevContainer Commands (Alternative):${NC}"
    echo "  code --folder-uri vscode-remote://dev-container+${WORKSPACE_ROOT}/.devcontainer/jazzy/devcontainer.json"
}

# Check if required tools are installed
check_requirements() {
    if ! command -v docker &> /dev/null; then
        echo -e "${RED}Error: Docker is not installed${NC}"
        exit 1
    fi
    
    if ! command -v docker compose &> /dev/null; then
        echo -e "${RED}Error: Docker Compose is not installed${NC}"
        exit 1
    fi
}

# Setup environment variables for docker-compose
setup_env() {
    # Check for conda directory
    if [ -d "/mnt/cave/.conda_docker" ] && [ "$(ls -A /mnt/cave/.conda_docker 2>/dev/null)" ]; then
        export CONDA_MOUNT="/mnt/cave/.conda_docker"
    else
        # Create empty directory for mount
        mkdir -p /tmp/empty 2>/dev/null || true
        export CONDA_MOUNT="/tmp/empty"
    fi
    
    # Ensure DISPLAY is set
    export DISPLAY="${DISPLAY:-:0}"
    
    # Set ROS_DOMAIN_ID to 1 (fixed for this container)
    export ROS_DOMAIN_ID=1
}

# Build images
build_images() {
    local distro=$1
    local rebuild=${2:-false}
    
    echo -e "${YELLOW}Building images for ${distro}...${NC}"
    
    setup_env
    
    cd "$WORKSPACE_ROOT" || exit 1
    
    local build_args=""
    if [ "$rebuild" = true ]; then
        build_args="--no-cache --pull"
    fi
    
    # Build base image first
    if docker compose --profile build build ${build_args} base-dev; then
        echo -e "${GREEN}Base image built successfully${NC}"
    else
        echo -e "${RED}Base image build failed${NC}"
        return 1
    fi
    
    # Build overlay image
    if docker compose --profile "$distro" build ${build_args} "ros2-${distro}"; then
        echo -e "${GREEN}${distro} image built successfully${NC}"
    else
        echo -e "${RED}${distro} image build failed${NC}"
        return 1
    fi
}

# Start container
start_container() {
    local distro=$1
    local conda_env=$2
    
    echo -e "${GREEN}Starting ${distro} container...${NC}"
    
    setup_env
    
    cd "$WORKSPACE_ROOT" || exit 1
    
    # Start container in background
    if docker compose --profile "$distro" up -d "ros2-${distro}"; then
        echo -e "${GREEN}Container started${NC}"
        
        # Wait for container to be ready
        sleep 2
        
        # Enter container
        if [ -n "$conda_env" ]; then
            echo -e "${CYAN}Activating conda environment: ${conda_env}${NC}"
            docker compose --profile "$distro" exec "ros2-${distro}" bash -c \
                "source /opt/conda/etc/profile.d/conda.sh && conda activate $conda_env && exec bash"
        else
            docker compose --profile "$distro" exec "ros2-${distro}" bash
        fi
    else
        echo -e "${RED}Failed to start container${NC}"
        return 1
    fi
}

# Prune containers and images
prune_containers() {
    local distro=$1
    
    echo -e "${RED}Pruning ${distro} container and images...${NC}"
    
    cd "$WORKSPACE_ROOT" || exit 1
    
    # Stop and remove containers
    docker compose --profile "$distro" down
    
    # Remove images
    docker rmi "robotics-dev:${distro}" 2>/dev/null || true
    
    # If pruning specific distro, ask about base image
    read -p "Remove base image? (y/N) " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        docker rmi robotics-dev-base:latest 2>/dev/null || true
    fi
    
    echo -e "${GREEN}Pruning complete${NC}"
}

# Open in VS Code
open_vscode() {
    local distro=$1
    
    echo -e "${CYAN}Opening in VS Code (${distro})...${NC}"
    
    cd "$WORKSPACE_ROOT" || exit 1
    
    # Open with specific devcontainer config
    if command -v code &> /dev/null; then
        # Use devcontainer CLI or VS Code command palette
        code --folder-uri "vscode-remote://dev-container+$(echo -n "${WORKSPACE_ROOT}/.devcontainer/${distro}/devcontainer.json" | xxd -plain | tr -d '\n' | sed 's/\(..\)/%\1/g')"
    else
        echo -e "${YELLOW}VS Code not found. Install VS Code or use regular mode.${NC}"
        echo -e "${CYAN}Install: https://code.visualstudio.com/${NC}"
    fi
}

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --jazzy)
            ROS_DISTRO="jazzy"
            shift
            ;;
        --conda)
            CONDA_ENV="$2"
            shift 2
            ;;
        --build)
            BUILD_ONLY=true
            shift
            ;;
        --rebuild)
            BUILD_ONLY=true
            REBUILD=true
            shift
            ;;
        --prune)
            PRUNE_CONTAINER=true
            shift
            ;;
        --vscode)
            VSCODE=true
            shift
            ;;
        --help|-h)
            show_help
            exit 0
            ;;
        *)
            echo -e "${RED}Unknown option: $1${NC}"
            show_help
            exit 1
            ;;
    esac
done

# Main execution
check_requirements

if [ "$PRUNE_CONTAINER" = true ]; then
    prune_containers "$ROS_DISTRO"
elif [ "$BUILD_ONLY" = true ]; then
    build_images "$ROS_DISTRO" "${REBUILD:-false}"
elif [ "$VSCODE" = true ]; then
    open_vscode "$ROS_DISTRO"
else
    start_container "$ROS_DISTRO" "$CONDA_ENV"
fi
